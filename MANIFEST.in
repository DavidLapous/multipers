recursive-include multipers *.py *.tp *.pxd *.h *.pyx *.hpp
prune ext
include ext/AIDA/CMakeLists.txt
recursive-include ext *.h *.hpp *.cpp LICENSE COPYING COPYING.LESSER
include tools/tempita_grid_gen.py
