{{endfor}}
    throw std::runtime_error("Unsupported SimplexTreeMulti type.");
  }, "simplextree"_a, "grid_shape"_a, "zero_pad"_a = false, "verbose"_a = false);

  m.def("_compute_rank_tensor", [](nb::handle simplextree, nb::handle grid_shape_handle, nb::handle degrees_handle, mpst::indices_type n_jobs, bool expand_collapse) {
    auto grid_shape = mpst::vector_from_handle<mpst::indices_type>(grid_shape_handle);
    auto degrees = mpst::vector_from_handle<mpst::indices_type>(degrees_handle);
    std::vector<mpst::indices_type> full_shape;
    full_shape.reserve(1 + 2 * grid_shape.size());
    full_shape.push_back((mpst::indices_type) degrees.size());
    full_shape.insert(full_shape.end(), grid_shape.begin(), grid_shape.end());
    full_shape.insert(full_shape.end(), grid_shape.begin(), grid_shape.end());
    size_t total = 1;
    for (mpst::indices_type value : full_shape) total *= (size_t) value;
    std::vector<mpst::tensor_dtype> container(total, 0);
    if (false) {
      throw std::runtime_error("unreachable");
    }
{{for D in to_iter}}
    else if (nb::isinstance<mpst::PySimplexTree<Gudhi::multiparameter::python_interface::Simplex_tree_multi_interface<{{D['CFil']}}, {{D['CTYPE']}}>, {{D['CTYPE']}}>>(simplextree)) {
      auto& st = nb::cast<mpst::PySimplexTree<Gudhi::multiparameter::python_interface::Simplex_tree_multi_interface<{{D['CFil']}}, {{D['CTYPE']}}>, {{D['CTYPE']}}>&>(simplextree).tree;
      Gudhi::multiparameter::rank_invariant::compute_rank_invariant_python(st, container.data(), full_shape, degrees, n_jobs, expand_collapse);
      return nb::make_tuple(
          nb::cast(mpst::owned_array<mpst::tensor_dtype>(std::move(container), {total})),
          nb::cast(full_shape));
    }
{{endfor}}
    throw std::runtime_error("Unsupported SimplexTreeMulti type.");
  }, "simplextree"_a, "grid_shape"_a, "degrees"_a, "n_jobs"_a = 0, "expand_collapse"_a = false);

  m.attr("available_simplextrees") = available_simplextrees;
}
