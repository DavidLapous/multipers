      auto sm = Gudhi::multiparameter::hilbert_function::get_hilbert_signed_measure(st, container.data(), full_shape, degrees, zero_pad, n_jobs, verbose, expand_collapse);
      return mpst::signed_measure_to_python(sm, width);
    }
{{endfor}}
