def _signed_measure_from_scc(minimal_presentation):
    cdef Py_ssize_t i
    cdef Py_ssize_t n = len(minimal_presentation)
    cdef Py_ssize_t total_size = 0
    cdef Py_ssize_t block_size
    cdef Py_ssize_t offset = 0
    cdef double[::1] weights_view

    if n == 0:
        return [(np.empty((0, 0)), np.empty((0,), dtype=np.float64))]

    pts_per_block = [block[0] for block in minimal_presentation]
    block_sizes = [len(block_pts) for block_pts in pts_per_block]
    for block_size in block_sizes:
        total_size += block_size

    pts = np.concatenate(pts_per_block)
    weights = np.empty(total_size, dtype=np.float64)
    weights_view = weights

    for i in range(n):
        block_size = block_sizes[i]
        weights_view[offset:offset + block_size] = 1.0 if (i & 1) == 0 else -1.0
        offset += block_size

    return [(pts, weights)]


