"""
Vine and non-vine slicers.
both type have the same interface, defined the slicer.pyx file
"""


import pickle
import os
from pathlib import Path

TEMPITA_CACHE_DIR = Path(os.environ.get("MULTIPERS_TEMPITA_CACHE_DIR", "build/tmp"))

with (TEMPITA_CACHE_DIR / "_slicer_names.pkl").open("rb") as f:
  slicers=pickle.load(f)

dtypes = set([(D['PY_VALUE_TYPE'], D['C_VALUE_TYPE'], D['SHORT_VALUE_TYPE']) for D in slicers])

with (TEMPITA_CACHE_DIR / "_simplextrees_.pkl").open("rb") as f:
    simplex_trees = pickle.load(f)

with (TEMPITA_CACHE_DIR / "_codegen_defaults.pkl").open("rb") as f:
    _codegen_defaults = pickle.load(f)

DEFAULT_COLUMN_TYPE = _codegen_defaults["default_column_type"]

}}

